# ============================================
# DNA Studio Configuration
# ============================================

# Database
DATABASE_URL="postgresql://dnastudio:dnastudio@localhost:5432/dnastudio"

# Redis (for job queue)
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"  # openssl rand -base64 32

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# AI Provider (choose one)
# ============================================
LLM_PROVIDER="openai"  # openai | anthropic | ollama | gemini

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"  # optional, defaults to gpt-4o

# Anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"  # optional

# Google Gemini
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-1.5-pro"  # optional

# Ollama (local)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"  # optional

# ============================================
# Image Generation (choose one)
# ============================================
IMAGE_PROVIDER="openai"  # openai | gemini | stability | replicate

# Stability AI
STABILITY_API_KEY=""

# Replicate (Flux)
REPLICATE_API_TOKEN=""
REPLICATE_MODEL="black-forest-labs/flux-schnell"  # optional

# ============================================
# UGC Video Generation (choose one)
# ============================================
VIDEO_PROVIDER="veo"  # veo | heygen | did

# HeyGen
HEYGEN_API_KEY=""

# D-ID
DID_API_KEY=""

# ============================================
# Social Media APIs (for publishing)
# ============================================

# Twitter/X API v2
TWITTER_API_KEY=""
TWITTER_API_SECRET=""

# Meta (Facebook/Instagram) — configured per-user via OAuth
# LinkedIn — configured per-user via OAuth
